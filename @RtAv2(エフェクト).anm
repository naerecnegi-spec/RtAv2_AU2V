@斜めクリッピング
--track0:中心X,-2000,2000,0
--track1:中心Y,-2000,2000,0
--track2:角度,-360,360,0
--track3:範囲ms,0,10000,0
--dialog:ぼかし,_1=0;幅,_2=0;逆モード/chk,_3=0;連動-X,_4="1";-Y,_5="1";-角,_6="1";ターゲット-X,_7="01";-Y,_8="01";-角,_9="01";イージング-X,_10=1;-Y,_11=1;-角,_12=1;サイズ固定/chk,_13=0;対象トラック-X,_14={0};-Y,_15={0};-角,_16={0};ピッチ/chk,_17=0;オプション,_18=0;

local RF=require("RtAv2Function")
local RtA=require("RtAv2")

local x,y,z = obj.track0,obj.track1,obj.track2
local range = obj.track3/1000

local px,py,pz = _4 or "0",_5 or "0",_6 or "0"
px,py,pz = (px=="") and "0" or px , (py=="") and "0" or py , (pz=="") and "0" or pz

local hx,hy,hz = _7 or "01",_8 or "01",_9 or "01"
hx,hy,hz = (hx=="") and "0" or hx , (hy=="") and "0" or hy , (hz=="") and "0" or hz

local ex,ey,ez = _10 or 1 ,_11 or 1 ,_12 or 1
local fixed = _13 or 0

local tx,ty,tz = _14 or {0},_15 or {0},_16 or {0}
tx = (RtA.type(tx)=="number") and {tx} or tx
ty = (RtA.type(ty)=="number") and {ty} or ty
tz = (RtA.type(tz)=="number") and {tz} or tz

local pich=_17 or 0
local option=_18 or 0

local blur = _1 or 0
local width = _2 or 0
local inv = _3 or 0

local function f(rpp,info,data)
    local pos=RF.getXYZ(rpp,info,data)
    obj.effect("斜めクリッピング", "中心X", pos[1], "中心Y", pos[2], "角度", pos[3], "ぼかし", data.blur, "幅", data.width, "逆モード", data.inv)
    
    if(data.fixed~=0)then
        RF.draw()
    end
end

local v={
    p={px,py,pz},
    h={hx,hy,hz},
    e={ex,ey,ez},
    t={tx,ty,tz},
    range=range,fixed=fixed,pich=pich,
    option=option,
    blur=blur, width=width, inv=inv,
    v={x,y,z},
}

RF.addFunction(f,v)