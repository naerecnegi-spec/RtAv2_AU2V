@クリッピング
--track0:上,0,2000,0
--track1:下,0,2000,0
--track2:左,0,2000,0
--track3:右,0,2000,0
--dialog:範囲ms,_1=0;連動-上,_2="1";-下,_3="1";-左,_4="1";-右,_5="1";ターゲット-上,_6="01";-下,_7="01";-左,_8="01";-右,_9="01";イージング-上,_10=1;-下,_11=1;-左,_12=1;-右,_13=1;サイズ固定/chk,_14=0;対象トラック-上,_15={0};-下,_16={0};-左,_17={0};-右,_18={0};ピッチ/chk,_19=0;オプション,_20=0;

local RF=require("RtAv2Function")
local RtA=require("RtAv2")

local x,y,z,w = obj.track0,obj.track1,obj.track2,obj.track3
local range = (_1 or 0)/1000

local px,py,pz,pw = _2 or "0",_3 or "0",_4 or "0",_5 or "0"
px,py,pz,pw = (px=="") and "0" or px , (py=="") and "0" or py , (pz=="") and "0" or pz , (pw=="") and "0" or pw

local hx,hy,hz,hw = _6 or "01",_7 or "01",_8 or "01",_9 or "01"
hx,hy,hz,hw = (hx=="") and "0" or hx , (hy=="") and "0" or hy , (hz=="") and "0" or hz , (hw=="") and "0" or hw

local ex,ey,ez,ew = _10 or 1 ,_11 or 1 ,_12 or 1 ,_13 or 1
local fixed = _14 or 0

local tx,ty,tz,tw = _15 or {0},_16 or {0},_17 or {0},_18 or {0}
tx = (RtA.type(tx)=="number") and {tx} or tx
ty = (RtA.type(ty)=="number") and {ty} or ty
tz = (RtA.type(tz)=="number") and {tz} or tz
tw = (RtA.type(tw)=="number") and {tw} or tw

