@拡大率

--track0:拡大率,-1000,1000,0

--track1:x,-1000,1000,0

--track2:y,-1000,1000,0

--track3:範囲ms,0,10000,0

--dialog:波形種類-率,_1="1";-x,_2="1";-y,_3="1";乗算種類-率,_4="01";-x,_5="01";-y,_6="01";イージング-率,_7=1;-x,_8=1;-y,_9=1;サイズ固定/chk,_10=0;対象-率,_11={0};-x,_12={0};-y,_13={0};音程/chk,_14=0;オプション,_15=0;



local RF=require("RtAv2Function")

local RtA=require("RtAv2")





--local x,y,z = obj.track0/100,obj.track1/100,obj.track2/100

local x,y,z = (obj.track0),(obj.track1),(obj.track2)

local range = obj.track3/1000



local px,py,pz = _1 or "0",_2 or "0",_3 or "0"

px,py,pz = (px=="") and "0" or px , (py=="") and "0" or py , (pz=="") and "0" or pz



local hx,hy,hz = _4 or "0",_5 or "0",_6 or "0"

hx,hy,hz = (hx=="") and "0" or hx , (hy=="") and "0" or hy , (hz=="") and "0" or hz



local ex,ey,ez = _7 or  1 ,_8 or  1 ,_9 or  1



local fixed = _10 or 0



local tx,ty,tz = _11  or {0},_12  or {0},_13  or {0}

tx = (RtA.type(tx)=="number") and {tx} or tx

ty = (RtA.type(ty)=="number") and {ty} or ty

tz = (RtA.type(tz)=="number") and {tz} or tz



local pich=_14 or 0

local option=_15 or 0





local function  f(rpp,info,data)

    

    local pos=RF.getXYZ(rpp,info,data)



    local zm,zx,zy=RF.ZOOM(pos[1]),RF.ZOOM(pos[2]),RF.ZOOM(pos[3])

    if(zx>=zy)then

        obj.zoom=zx*zm* obj.zoom

        obj.aspect = zy/zx -1

    else

        obj.zoom=zy*zm* obj.zoom

        obj.aspect = -zx/zy +1

    end



    if(data.fixed~=0)then

        RF.draw()

    end

end



local v={

            p={px,py,pz},

            h={hx,hy,hz},

            e={ex,ey,ez},

            t={tx,ty,tz},

            range=range,fixed=fixed,pich=pich,

            option=option,

            v={x,y,z},

        }



RF.addFunction(f,v)





@透明度

--track0:透明度,-100,100,0

--track3:範囲ms,0,10000,0

--dialog:波形種類,_1="1";乗算種類,_4="01";イージング,_7=1;サイズ固定/chk,_10=0;対象,_11={0};音程/chk,_14=0;オプション,_15=0;



local RF=require("RtAv2Function")

local RtA=require("RtAv2")



local x = obj.track0

local range = obj.track3/1000



local px = _1 or "0"

px = (px=="") and "0" or px 



local hx = _4 or "0"

hx = (hx=="") and "0" or hx 



local ex = _7 or  1



local fixed = _10 or 0



local tx = _11  or {0}

tx = (RtA.type(tx)=="number") and {tx} or tx



local pich=_14 or 0

local option=_15 or 0





local function  f(rpp,info,data)

    

    local pos=RF.getXYZ(rpp,info,data)

    pos[1]=RF.ALPHA(pos[1])



    obj.alpha=obj.alpha*pos[1]

    obj.alpha=math.min(obj.alpha,1)

    if(data.fixed~=0)then

        RF.draw()

    end

end



local v={

            p={px},

            h={hx},

            e={ex},

            t={tx},

            range=range,fixed=fixed,pich=pich,

            option=option,

            v={x},

        }



RF.addFunction(f,v)





@test



--track0:rx,-4000,4000,0

--track1:ry,-4000,4000,0

--track2:rz,-4000,4000,0

--check0:0,0



local x,y=50,100

local RF=require("RtAv2Function")

local rotationPos=RF.rotationPos



if(obj.check0)then

    obj.effect("拡大率","X",x,"Y",y)

    obj.rx,obj.ry,obj.rz=obj.track0,obj.track1,obj.track2

    obj.draw()

else



    local rx,ry,rz=obj.track0,obj.track1,obj.track2



    local w,h=(obj.w*(x/100))/2,(obj.h*(y/100))/2

    local x0,y0,z0 = rotationPos(-w,-h,0,rx,ry,rz)

    local x1,y1,z1 = rotationPos( w,-h,0,rx,ry,rz)

    local x2,y2,z2 = rotationPos( w, h,0,rx,ry,rz)

    local x3,y3,z3 = rotationPos(-w, h,0,rx,ry,rz)

    obj.drawpoly(
        x0,y0,z0,
        x1,y1,z1,
        x2,y2,z2,
        x3,y3,z3 
   )

end


@ラスター
--track0:横幅,0,2000,0
--track1:高さ,0,2000,0
--track2:周期,0,100,0
--track3:範囲ms,0,10000,0
--dialog:連動-横,_1="1";-縦,_2="1";-周,_3="1";ターゲット-横,_4="01";-縦,_5="01";-周,_6="01";イージング-横,_7=1;-縦,_8=1;-周,_9=1;サイズ固定/chk,_10=0;対象トラック-横,_11={0};-縦,_12={0};-周,_13={0};ピッチ/chk,_14=0;オプション,_15=0;縦ラスター/chk,_16=0;ランダム幅/chk,_17=0;

local RF=require("RtAv2Function")
local RtA=require("RtAv2")

local x,y,z = obj.track0,obj.track1,obj.track2
local range = obj.track3/1000

local px,py,pz = _1 or "0",_2 or "0",_3 or "0"
px,py,pz = (px=="") and "0" or px , (py=="") and "0" or py , (pz=="") and "0" or pz

local hx,hy,hz = _4 or "0",_5 or "0",_6 or "0"
hx,hy,hz = (hx=="") and "0" or hx , (hy=="") and "0" or hy , (hz=="") and "0" or hz

local ex,ey,ez = _7 or 1 ,_8 or 1 ,_9 or 1
local fixed = _10 or 0

local tx,ty,tz = _11 or {0},_12 or {0},_13 or {0}
tx = (RtA.type(tx)=="number") and {tx} or tx
ty = (RtA.type(ty)=="number") and {ty} or ty
tz = (RtA.type(tz)=="number") and {tz} or tz

local pich=_14 or 0
local option=_15 or 0

local vert = _16 or 0
local rand = _17 or 0

local function f(rpp,info,data)
    local pos=RF.getXYZ(rpp,info,data)
    obj.effect("ラスター", "横幅", pos[1], "高さ", pos[2], "周期", pos[3], "縦ラスター", data.vert, "ランダム幅", data.rand)
    
    if(data.fixed~=0)then
        RF.draw()
    end
end

local v={
    p={px,py,pz},
    h={hx,hy,hz},
    e={ex,ey,ez},
    t={tx,ty,tz},
    range=range,fixed=fixed,pich=pich,
    option=option,
    vert=vert, rand=rand,
    v={x,y,z},
}

RF.addFunction(f,v)


